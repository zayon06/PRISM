# =============================================================================
# PRISM — Environment Variables
# =============================================================================
# Copy this file to .env and fill in all values before running:
#   docker compose up -d --build
# =============================================================================

# ---- Domain / TLS -----------------------------------------------------------
# The domain name your application is served on (used in Traefik routing rules).
DOMAIN=example.com

# Email address for Let's Encrypt certificate notifications.
ACME_EMAIL=admin@example.com

# ---- PostgreSQL -------------------------------------------------------------
DB_NAME=prism
DB_USERNAME=prism
DB_PASSWORD=          # REQUIRED — set a strong password
DB_HOSTNAME=postgres  # matches the compose service name
DB_PORT=5432
DB_DRIVER=postgresql+asyncpg

# ---- Auth Service -----------------------------------------------------------
SECRET_KEY=           # REQUIRED — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
BACKEND_URL=https://${DOMAIN}/api/auth
